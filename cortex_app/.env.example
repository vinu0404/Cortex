# Environment
ENVIRONMENT=dev

# LLM
DEFAULT_MODEL=gpt-4o

# Database
DATABASE_URL=postgresql+asyncpg://cortex:cortex@localhost:5432/cortex

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# Qdrant
QDRANT_URL=http://localhost:6333

# Auth
JWT_SECRET=change-this-to-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (AES-256 key — must be 32 bytes base64 encoded)
ENCRYPTION_KEY=change-this-to-a-32-byte-base64-encoded-key

# Langfuse
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PROMPT_CACHE_TTL=300

# Memory
SHORT_TERM_MEMORY_WINDOW=10
SHORT_TERM_COMPRESS_FIRST_N=4

# Features
ENABLE_SUGGESTIONS=true

# HITL
HITL_TIMEOUT_SECONDS=120

# Token budget
TOKEN_BUDGET_ENABLED=true
USER_DAILY_TOKEN_BUDGET=100000
USER_MONTHLY_TOKEN_BUDGET=2000000

# LLM retries
LLM_MAX_RETRIES=3
LLM_RETRY_WAIT_MIN=1.0
LLM_RETRY_WAIT_MAX=30.0
LLM_RETRY_JITTER=2.0

# HTTP retries
HTTP_MAX_RETRIES=3
HTTP_RETRY_WAIT_MIN=1.0
HTTP_RETRY_WAIT_MAX=30.0
HTTP_RETRY_JITTER=1.0

# Redis retries
REDIS_MAX_RETRIES=2
REDIS_RETRY_WAIT_FIXED=0.5

# OAuth — Gmail / Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/connectors/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/connectors/callback

# OAuth — Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:8000/connectors/callback


TAVILY_API_KEY=tvly-dev-lWVejd950JBUNZIG...........