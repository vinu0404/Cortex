# Environment
ENVIRONMENT=dev

# LLM
DEFAULT_MODEL=gpt-5
VISION_MODEL=gpt-4o

# Database
DATABASE_URL=postgresql+asyncpg://cortex:cortex@localhost:5432/cortex

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# Qdrant
QDRANT_URL=http://localhost:6333

# Auth
JWT_SECRET=change-this-to-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (AES-256 key — must be 32 bytes base64 encoded)
ENCRYPTION_KEY=change-this-to-a-32-byte-base64-encoded-key

# Langfuse
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PROMPT_CACHE_TTL=300

# Memory
SHORT_TERM_MEMORY_WINDOW=10
SHORT_TERM_COMPRESS_FIRST_N=4

# Features
ENABLE_SUGGESTIONS=true

# HITL
HITL_TIMEOUT_SECONDS=120

# Token budget
TOKEN_BUDGET_ENABLED=true
USER_DAILY_TOKEN_BUDGET=100000
USER_MONTHLY_TOKEN_BUDGET=2000000

# LLM retries
LLM_MAX_RETRIES=3
LLM_RETRY_WAIT_MIN=1.0
LLM_RETRY_WAIT_MAX=30.0
LLM_RETRY_JITTER=2.0

# HTTP retries
HTTP_MAX_RETRIES=3
HTTP_RETRY_WAIT_MIN=1.0
HTTP_RETRY_WAIT_MAX=30.0
HTTP_RETRY_JITTER=1.0

# Redis retries
REDIS_MAX_RETRIES=2
REDIS_RETRY_WAIT_FIXED=0.5

# OAuth — Gmail / Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/connectors/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/connectors/callback

# OAuth — Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:8000/connectors/callback

# Tavily (web search)
TAVILY_API_KEY=tvly-...

# Backblaze B2 (file storage)
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_BUCKET=
B2_PRESIGN_EXPIRY=300

# Knowledge Bases
KB_EMBEDDING_MODEL=text-embedding-3-small
KB_EMBEDDING_DIMS=1536
KB_EMBED_BATCH_SIZE=96
KB_CHUNK_SIZE=1000
KB_CHUNK_OVERLAP=200
KB_CSV_ROWS_PER_CHUNK=100
KB_STAGING_DIR=./staging
KB_TOP_K_DENSE=50
KB_TOP_K_SPARSE=50
KB_TOP_K_RRF=20
KB_TOP_K_FINAL=5
KB_RRF_K=60
KB_RERANK_STRATEGY=none
KB_MAX_FILES_PER_UPLOAD=50
KB_MAX_FILE_SIZE_MB=100

# Website Collections
WC_MAX_URLS_PER_COLLECTION=50
WC_MAX_DEPTH=5
WC_CRAWL_TIMEOUT_SECONDS=600
WC_MAX_PAGES_PER_URL=500
WC_CONCURRENT_REQUESTS=8
WC_DOWNLOAD_TIMEOUT=30
WC_OBEY_ROBOTS=true
WC_USER_AGENT=CortexBot/1.0
WC_TOP_K_DENSE=50
WC_TOP_K_FINAL=5
